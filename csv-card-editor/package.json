{
  "name": "csv-card-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,vision -c cyan,magenta \"npm run dev:next\" \"npm run vision-server\"",
    "dev:next": "node --max-old-space-size=2048 node_modules/next/dist/bin/next dev",
    "dev:webpack": "concurrently -n next,vision -c cyan,magenta \"node --max-old-space-size=2048 node_modules/next/dist/bin/next dev --webpack\" \"npm run vision-server\"",
    "vision:deps": "npm run install-deps --prefix ../card-vision-main",
    "vision-server": "npm run server --prefix ../card-vision-main",
    "build": "node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "node --max-old-space-size=2048 node_modules/next/dist/bin/next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
